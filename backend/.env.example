APP_NAME=NMS Bahrain BookX API
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_DB_INIT=true
ENABLE_DOCS=true

# Hosted MySQL connection string. Keep real credentials in the deployment platform.
# Example: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Optional local MySQL pieces if DATABASE_URL is not set.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# JWT signing. SECRET_KEY is the production variable used by the app.
SECRET_KEY=change-this-to-a-long-random-secret
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
